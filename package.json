{
  "name": "allegro-ts",
  "description": "Allegro 4 brought to the browser",
  "version": "1.1.0",
  "repository": "https://github.com/alegemaate/allegro-ts",
  "keywords": [
    "allegro",
    "javascript",
    "game",
    "library"
  ],
  "files": [
    "dist"
  ],
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./global": {
      "types": "./dist/global.d.ts",
      "import": "./dist/global.mjs",
      "default": "./dist/global.mjs"
    }
  },
  "author": "Allan Legemaate <alegemaate@gmail.com>",
  "license": "MIT",
  "private": false,
  "main": "./dist/index.mjs",
  "scripts": {
    "prepare": "npm run build",
    "prepublishOnly": "npm run lint",
    "preversion": "npm run lint",
    "build": "vite build && cp ./src/global-types.d.ts ./dist/global.d.ts",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.0.0",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-tsdoc": "^0.5.2",
    "prettier": "^3.8.1",
    "typedoc": "^0.28.17",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4"
  }
}
